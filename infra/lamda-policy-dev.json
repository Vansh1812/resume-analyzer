{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": ["s3:GetObject"],
      "Resource": "arn:aws:s3:::resume-analyzer-uploads-*/*"
    },
    {
      "Effect": "Allow",
      "Action": ["textract:StartDocumentTextDetection","textract:GetDocumentTextDetection"],
      "Resource": "*"
    },
    {
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup","logs:CreateLogStream","logs:PutLogEvents"],
      "Resource": "arn:aws:logs:us-east-1:*:log-group:/aws/lambda/resume-processor*"
    }
  ]
}